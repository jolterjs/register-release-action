{
  "name": "@jolter/register-release-action",
  "version": "1.0.0",
  "description": "GitHub Action that registers Jolter plugin releases with the Jolter registry.",
  "type": "module",
  "main": "dist/index.js",
  "homepage": "https://jolter.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/jolterjs/register-release-action.git"
  },
  "bugs": {
    "url": "https://github.com/jolterjs/register-release-action/issues"
  },
  "author": {
    "name": "JolterJS",
    "url": "https://jolter.dev"
  },
  "scripts": {
    "build": "ncc build src/index.ts -o dist --minify --source-map",
    "typecheck": "tsc --noEmit",
    "format": "prettier -w .",
    "format:check": "prettier --check .",
    "test": "bun test"
  },
  "keywords": [
    "jolter",
    "github-action",
    "release",
    "registry",
    "plugin"
  ],
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "semver": "^7.7.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.0",
    "@types/semver": "^7.7.0",
    "@vercel/ncc": "^0.44.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  }
}
